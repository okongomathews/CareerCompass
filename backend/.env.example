# ─────────────────────────────────────────────────────────────────────────────
# CareerCompass Kenya — Environment Variables
# Copy to .env and fill in your values:   cp .env.example .env
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-this-with-a-long-random-string-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# Create with:
#   sudo -u postgres psql
#   CREATE DATABASE careercompass;
#   CREATE USER careercompass_user WITH PASSWORD 'your_password';
#   GRANT ALL PRIVILEGES ON DATABASE careercompass TO careercompass_user;
DB_NAME=careercompass
DB_USER=careercompass_user
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432

# ── Email (required for OTP password reset and welcome emails) ────────────────
# Gmail: enable 2FA → myaccount.google.com → Security → App Passwords → create one
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-gmail-address@gmail.com
EMAIL_HOST_PASSWORD=abcd efgh ijkl mnop
DEFAULT_FROM_EMAIL=CareerCompass Kenya <your-gmail-address@gmail.com>
# Leave EMAIL_HOST / EMAIL_HOST_USER / EMAIL_HOST_PASSWORD blank to print
# OTP codes to the terminal instead (fine for local development).

# ── Site URL (used in password reset links) ───────────────────────────────────
SITE_URL=http://127.0.0.1:8000

# ── AI / LLM (optional — app works without these, falls back to rule-based) ───
# OpenAI: platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# HuggingFace (optional, raises free API rate limits):
# huggingface.co/settings/tokens → New token (read)
HF_API_TOKEN=hf_...

# Model settings (defaults shown — change only if you know what you're doing)
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=600
